---
import { nav } from '../data/site';
---
<header class="nav">
  <div class="wrap nav-in">
    <a href="/" aria-label="MÁS VIDRIOS inicio"><img src="/brand/logo.png" alt="MÁS VIDRIOS" width="170" height="38" /></a>
    <nav id="navmenu">
      <ul>
        <li><a href="/">Inicio</a></li>
        {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
        <li><a class="lang-link" href="/en/" hreflang="en" lang="en" aria-label="English version">EN</a></li>
        <li><a class="btn btn-primary cta" href="/contacto/">Pedir presupuesto</a></li>
      </ul>
    </nav>
    <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" id="navtoggle">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </div>
</header>
<script is:inline>
  (function(){
    var t=document.getElementById('navtoggle'),m=document.getElementById('navmenu');
    if(!t||!m)return;
    t.addEventListener('click',function(){
      var open=m.classList.toggle('open');
      t.setAttribute('aria-expanded',open?'true':'false');
    });
    m.addEventListener('click',function(e){if(e.target.tagName==='A')m.classList.remove('open');});
  })();
</script>
<style>
  .lang-link{font-weight:700;font-size:13px;letter-spacing:.5px;padding:6px 12px;border-radius:999px;border:1.5px solid var(--linea);color:var(--tinta)!important;transition:.18s}
  .lang-link:hover{border-color:var(--azul);color:var(--azul)!important}
  @media(max-width:900px){.lang-link{display:inline-block;text-align:center}}
</style>
