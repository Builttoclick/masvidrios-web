---
import Base from '../layouts/Base.astro';

const WA = 'https://wa.me/595984452749';

const servicios = [
  { t: 'Colocación de vidrios', d: 'Vidrio templado y crudo, colocado en obra con terminación prolija.',
    icon: '<rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 3v18"/>' },
  { t: 'Cerramientos & galerías', d: 'Cerrá quinchos, galerías y patios con vidrio y aluminio, sin perder la vista.',
    icon: '<path d="M4 20V8l8-5 8 5v12"/><path d="M9 20v-6h6v6"/>' },
  { t: 'Mamparas de baño', d: 'Vidrio templado de seguridad, robusto y de durabilidad garantizada.',
    icon: '<rect x="3" y="4" width="18" height="16" rx="1"/><path d="M3 4l9 8 9-8"/>' },
  { t: 'Divisorias de oficina', d: 'Aislamiento acústico y térmico, diseño a medida para tu espacio de trabajo.',
    icon: '<rect x="3" y="3" width="18" height="18" rx="1"/><path d="M12 3v18"/>' },
  { t: 'Aberturas de aluminio', d: 'Líneas suprema, 25 y módulo práctico. También símil madera y mosquiteros.',
    icon: '<rect x="2" y="6" width="20" height="12" rx="1"/><path d="M6 6v12M10 6v12M14 6v12M18 6v12"/>' },
  { t: 'Cielo raso & Durlock', d: 'Cielo raso desmontable de yeso/PVC y tabiques de construcción en seco.',
    icon: '<path d="M3 12h18"/><path d="M3 6h18M3 18h18"/>' },
  { t: 'Barandas vidriadas', d: 'Vidrio combinado con aluminio y acero inoxidable, seguras y elegantes.',
    icon: '<path d="M4 18V9M9 18V5M14 18v-7M19 18V8"/><path d="M3 21h18"/>' },
  { t: 'Policarbonato', d: 'Techos y cubiertas translúcidas, resistentes y livianas.',
    icon: '<path d="M3 7l9-4 9 4-9 4-9-4Z"/><path d="M3 7v6l9 4 9-4V7"/>' },
  { t: 'Mantenimientos', d: 'Servicio y reparación de tus instalaciones de vidrio y aluminio.',
    icon: '<circle cx="12" cy="12" r="3"/><path d="M19 12a7 7 0 0 0-.1-1l2-1.6-2-3.4-2.4 1a7 7 0 0 0-1.7-1L14.5 3h-5L9 5a7 7 0 0 0-1.7 1l-2.4-1-2 3.4 2 1.6a7 7 0 0 0 0 2l-2 1.6 2 3.4 2.4-1a7 7 0 0 0 1.7 1l.5 2h5l.5-2a7 7 0 0 0 1.7-1l2.4 1 2-3.4-2-1.6a7 7 0 0 0 .1-1Z"/>' },
];

const proyectos = [
  { img: 'puerta-vidrio-corrediza-aluminio-negro-living-piscina-02.jpg', cap: 'Cerramiento corredizo · aluminio negro', cls: 'tall wide',
    alt: 'Cerramiento de vidrio corredizo con marco de aluminio negro hacia el jardín — MÁS VIDRIOS' },
  { img: 'mesa-vidrio-templado-curvado-mobiliario-01.jpg', cap: 'Mobiliario en vidrio templado', cls: '',
    alt: 'Mesa de vidrio templado curvado de dos niveles hecha a medida — MÁS VIDRIOS' },
  { img: 'cerramiento-galeria-vidrio-marco-madera-exterior.jpg', cap: 'Galería cerrada · símil madera', cls: '',
    alt: 'Cerramiento de galería con vidrio y carpintería color madera — MÁS VIDRIOS' },
  { img: 'muro-cortina-vidrio-fachada-edificio-ladrillo.jpg', cap: 'Muro cortina · fachada comercial', cls: '',
    alt: 'Muro cortina de vidrio en fachada de edificio con ladrillo visto — MÁS VIDRIOS' },
  { img: 'divisiones-vidrio-aluminio-negro-oficina-corporativa.jpg', cap: 'Divisiones de oficina · aluminio negro', cls: 'wide',
    alt: 'Divisiones de vidrio con aluminio negro en oficina corporativa — MÁS VIDRIOS' },
  { img: 'puerta-corrediza-vidrio-aluminio-negro-estilo-industrial-cuadricula.jpg', cap: 'Corrediza estilo industrial', cls: '',
    alt: 'Puerta corrediza de vidrio estilo industrial con cuadrícula — MÁS VIDRIOS' },
];
---
<Base>
  <!-- NAV -->
  <header class="nav">
    <div class="wrap nav-in">
      <a href="/" aria-label="MÁS VIDRIOS inicio"><img src="/brand/logo.png" alt="MÁS VIDRIOS" width="170" height="38" /></a>
      <nav><ul>
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#proyectos">Proyectos</a></li>
        <li><a href="#destacados">Trabajos</a></li>
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul></nav>
      <a class="btn btn-primary cta" href="#contacto">Pedir presupuesto</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">Vidrio templado · Aluminio · San Lorenzo</span>
          <h1>Transparencia que <span class="hl">transforma</span> tu espacio</h1>
          <p class="lead">Cerramientos, mamparas, divisorios y aberturas de vidrio y aluminio, instalados con precisión. Empresa familiar desde 2009.</p>
          <div class="hero-actions">
            <a class="btn btn-wa" href={WA} target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Z"/></svg>
              WhatsApp 0984 452 749
            </a>
            <a class="btn btn-ghost" href="#proyectos">Ver proyectos</a>
          </div>
        </div>
        <div class="hero-media">
          <img src="/fotos/proyectos/divisiones-oficina-vidrio-aluminio-blanco-interior.jpg" alt="Divisiones de oficina en vidrio con aluminio blanco — MÁS VIDRIOS" width="900" height="600" />
          <div class="hero-badge"><b>2009</b><span>Más de 15 años<br>cerrando con vidrio</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <div class="trust">
    <div class="wrap">
      <div class="item"><b><span class="g">+15</span> años</b><span>de experiencia en obra</span></div>
      <div class="item"><b>Olimpia</b><span>Palcos VIP · Estadio M. Ferreira</span></div>
      <div class="item"><b>ANDE</b><span>Fachada SITRANDE, Asunción</span></div>
      <div class="item"><b>Presupuesto</b><span>sin compromiso · vamos a tu obra</span></div>
    </div>
  </div>

  <!-- SERVICIOS -->
  <section id="servicios">
    <div class="wrap center">
      <span class="eyebrow">Lo que hacemos</span>
      <h2 class="sec">Soluciones en vidrio &amp; mucho más</h2>
      <p class="sec-sub">Del vidrio templado a la carpintería de aluminio: proveemos e instalamos, a medida y a tu presupuesto.</p>
    </div>
    <div class="wrap">
      <div class="cards">
        {servicios.map((s) => (
          <div class="card">
            <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALERIA -->
  <section id="proyectos" class="gal">
    <div class="wrap center">
      <span class="eyebrow">Portfolio</span>
      <h2 class="sec">Proyectos que hablan por nosotros</h2>
      <p class="sec-sub">Residencias, oficinas y locales en todo el país. Una muestra de trabajos terminados.</p>
    </div>
    <div class="wrap">
      <div class="grid-gal">
        {proyectos.map((p) => (
          <figure class={p.cls}>
            <img src={`/fotos/proyectos/${p.img}`} alt={p.alt} loading="lazy" />
            <figcaption>{p.cap}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- DESTACADOS -->
  <section id="destacados">
    <div class="wrap">
      <div class="feat"><div class="feat-in">
        <span class="eyebrow">Obras destacadas</span>
        <h2>Cuando el trabajo tiene que estar impecable, nos llaman a nosotros.</h2>
        <div class="feat-list">
          <div class="feat-item"><div class="dot">★</div><div><h4>Palcos VIP — Club Olimpia</h4><p>Vidriado de los palcos VIP del Estadio Manuel Ferreira.</p></div></div>
          <div class="feat-item"><div class="dot">★</div><div><h4>Fachada SITRANDE / ANDE</h4><p>Fachada del sindicato de la ANDE sobre Tte. Fariña, Asunción.</p></div></div>
          <div class="feat-item"><div class="dot">✦</div><div><h4>Residencias &amp; oficinas</h4><p>Cerramientos, divisorios y aberturas en obra pública y privada.</p></div></div>
          <div class="feat-item"><div class="dot">✦</div><div><h4>Locales comerciales</h4><p>Vidrieras, muros cortina y fachadas de gran formato.</p></div></div>
        </div>
      </div></div>
    </div>
  </section>

  <!-- NOSOTROS -->
  <section id="nosotros" class="gal">
    <div class="wrap center">
      <span class="eyebrow">Quiénes somos</span>
      <h2 class="sec">Una empresa familiar, desde 2009</h2>
      <p class="story">Nacimos de la experiencia acumulada por nuestra familia en el rubro del vidrio. Trabajamos con honestidad, responsabilidad, seriedad y puntualidad — orientando cada servicio a proteger la inversión de nuestros clientes.</p>
      <div class="team">
        <div class="person">
          <div class="ph"><img src="/fotos/equipo/jose.jpg" alt="José — Fundador y Director de MÁS VIDRIOS" loading="lazy" /></div>
          <div class="body"><h4>José</h4><div class="role">Fundador &amp; Director</div></div>
        </div>
        <div class="person">
          <div class="ph"><img src="/fotos/equipo/erika.jpg" alt="Erika — Administración de MÁS VIDRIOS" loading="lazy" /></div>
          <div class="body"><h4>Erika</h4><div class="role">Administración &amp; Atención al Cliente</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contacto">
    <div class="wrap">
      <div class="ctaband">
        <h2>Contanos tu proyecto</h2>
        <p>Te asesoramos y vamos a tu obra o domicilio. Presupuesto sin compromiso.</p>
        <a class="btn btn-primary" href={WA} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Z"/></svg>
          Escribinos por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <img class="logo" src="/brand/logo-white.png" alt="MÁS VIDRIOS" width="180" height="42" />
          <p class="foot-about">Soluciones en vidrio &amp; mucho más. Vidrio templado, aluminio, cerramientos y divisorios. San Lorenzo, Paraguay.</p>
        </div>
        <div>
          <h5>Servicios</h5>
          <ul>
            <li><a href="#servicios">Colocación de vidrios</a></li>
            <li><a href="#servicios">Cerramientos</a></li>
            <li><a href="#servicios">Mamparas</a></li>
            <li><a href="#servicios">Divisorias de oficina</a></li>
            <li><a href="#servicios">Aberturas de aluminio</a></li>
          </ul>
        </div>
        <div>
          <h5>Contacto</h5>
          <ul>
            <li><a href={WA}>WhatsApp: 0984 452 749</a></li>
            <li><a href="mailto:jose@masvidrios.com.py">jose@masvidrios.com.py</a></li>
            <li><a href="https://www.facebook.com/MASVidrios-461790940665213/" target="_blank" rel="noopener">Facebook</a></li>
            <li class="muted">San Lorenzo, Paraguay</li>
          </ul>
          <div style="margin-top:14px"><a class="wa-pill" href={WA}>Escribir ahora</a></div>
        </div>
      </div>
      <div class="foot-bot">
        <span>© 2026 MÁS VIDRIOS. Todos los derechos reservados.</span>
        <span>Hecho por Built to Click</span>
      </div>
    </div>
  </footer>
</Base>

<style>
  .wrap{max-width:1140px;margin:0 auto;padding:0 24px}
  .eyebrow{font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--azul)}
  h2.sec{font-size:34px;font-weight:800;letter-spacing:-.8px;color:var(--negro);margin:8px 0 6px;line-height:1.15}
  .sec-sub{color:var(--gris);max-width:620px;font-size:16px}
  .center{text-align:center}.center .sec-sub{margin:0 auto}
  section{padding:88px 0}

  .btn{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:15px;padding:14px 26px;border-radius:12px;transition:.18s;cursor:pointer;border:none}
  .btn-primary{background:var(--azul);color:#fff;box-shadow:0 10px 24px rgba(36,120,252,.30)}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(36,120,252,.40)}
  .btn-ghost{background:rgba(255,255,255,.7);color:var(--negro);box-shadow:inset 0 0 0 1.5px var(--linea)}
  .btn-ghost:hover{box-shadow:inset 0 0 0 1.5px var(--azul);color:var(--azul)}
  .btn-wa{background:#25D366;color:#fff;box-shadow:0 10px 24px rgba(37,211,102,.30)}
  .btn-wa:hover{transform:translateY(-2px)}

  .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--linea)}
  .nav-in{display:flex;align-items:center;justify-content:space-between;height:74px}
  .nav img{height:38px;width:auto}
  .nav ul{display:flex;gap:30px;list-style:none;font-size:15px;font-weight:500}
  .nav ul a{color:var(--tinta)}.nav ul a:hover{color:var(--azul)}
  .nav .cta{font-size:14px;padding:11px 20px}
  @media(max-width:820px){.nav ul{display:none}}

  .hero{padding:0;background:var(--bg2)}
  .hero-grid{display:grid;grid-template-columns:1.05fr 1fr;align-items:center;gap:50px;min-height:560px}
  .hero-copy{padding:70px 0}
  .hero h1{font-size:52px;line-height:1.07;letter-spacing:-1.6px;font-weight:800;color:var(--negro);margin:16px 0 18px}
  .hero h1 .hl{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
  .hero p.lead{font-size:18px;color:var(--gris);max-width:480px;margin-bottom:30px}
  .hero-actions{display:flex;gap:14px;flex-wrap:wrap}
  .hero-media{position:relative;height:100%;min-height:560px;border-radius:0}
  .hero-media>img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .hero-badge{position:absolute;left:-30px;bottom:46px;z-index:3;background:rgba(255,255,255,.88);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.9);box-shadow:var(--shadow);border-radius:16px;padding:16px 20px;display:flex;align-items:center;gap:14px}
  .hero-badge b{font-size:26px;color:var(--azul);font-weight:800;line-height:1}
  .hero-badge span{font-size:12.5px;color:var(--gris)}
  @media(max-width:860px){.hero-grid{grid-template-columns:1fr;min-height:auto}.hero-media{min-height:320px;margin-bottom:0}.hero-copy{padding:54px 0 30px}.hero h1{font-size:38px}.hero-badge{left:16px}}

  .trust{background:var(--negro);color:#fff}
  .trust .wrap{display:flex;flex-wrap:wrap;justify-content:space-between;gap:20px;padding:26px 24px}
  .trust .item{display:flex;flex-direction:column}
  .trust .item b{font-size:24px;font-weight:800;color:#fff}
  .trust .item b .g{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
  .trust .item span{font-size:13px;color:#9aa3b2}

  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:48px}
  @media(max-width:860px){.cards{grid-template-columns:1fr 1fr}}
  @media(max-width:560px){.cards{grid-template-columns:1fr}}
  .card{background:#fff;border:1px solid var(--linea);border-radius:var(--radius);padding:30px 26px;transition:.2s}
  .card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:transparent}
  .card .ic{width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,rgba(36,120,252,.12),rgba(84,228,228,.18));display:flex;align-items:center;justify-content:center;margin-bottom:18px}
  .card .ic svg{width:26px;height:26px;stroke:var(--azul);fill:none;stroke-width:1.8}
  .card h3{font-size:18px;font-weight:700;color:var(--negro);margin-bottom:6px}
  .card p{font-size:14.5px;color:var(--gris)}

  .gal{background:var(--bg2)}
  .grid-gal{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:200px;gap:16px;margin-top:46px}
  .grid-gal figure{position:relative;border-radius:16px;overflow:hidden;box-shadow:0 8px 24px rgba(20,40,90,.08)}
  .grid-gal img{width:100%;height:100%;object-fit:cover;transition:.4s}
  .grid-gal figure:hover img{transform:scale(1.06)}
  .grid-gal figcaption{position:absolute;left:0;right:0;bottom:0;padding:14px 16px;font-size:13px;font-weight:600;color:#fff;background:linear-gradient(0deg,rgba(15,25,45,.78),transparent)}
  .tall{grid-row:span 2}.wide{grid-column:span 2}
  @media(max-width:860px){.grid-gal{grid-template-columns:1fr 1fr}.tall{grid-row:auto}}
  @media(max-width:560px){.grid-gal{grid-template-columns:1fr}.wide,.tall{grid-column:auto;grid-row:auto}}

  .feat{background:var(--negro);color:#fff;border-radius:26px;overflow:hidden;position:relative}
  .feat::before{content:"";position:absolute;right:-80px;top:-80px;width:340px;height:340px;background:var(--grad);filter:blur(20px);opacity:.30;border-radius:50%}
  .feat-in{position:relative;padding:60px 54px}
  .feat .eyebrow{color:var(--celeste)}
  .feat h2{font-size:30px;font-weight:800;letter-spacing:-.5px;margin:8px 0 26px;max-width:680px;line-height:1.2}
  .feat-list{display:grid;grid-template-columns:1fr 1fr;gap:22px}
  @media(max-width:680px){.feat-list{grid-template-columns:1fr}.feat-in{padding:40px 26px}}
  .feat-item{display:flex;gap:14px;align-items:flex-start}
  .feat-item .dot{flex:0 0 auto;width:42px;height:42px;border-radius:11px;background:rgba(255,255,255,.07);display:flex;align-items:center;justify-content:center;font-weight:800;color:var(--celeste)}
  .feat-item h4{font-size:17px;font-weight:700;color:#fff}
  .feat-item p{font-size:14px;color:#aab2c0}

  .team{display:grid;grid-template-columns:repeat(2,1fr);gap:26px;margin-top:48px;max-width:760px;margin-left:auto;margin-right:auto}
  .person{background:#fff;border:1px solid var(--linea);border-radius:20px;overflow:hidden;text-align:center;transition:.2s}
  .person:hover{box-shadow:var(--shadow);transform:translateY(-4px)}
  .person .ph{aspect-ratio:1/1;overflow:hidden;background:#222}
  .person .ph img{width:100%;height:100%;object-fit:cover;filter:grayscale(.15)}
  .person .body{padding:20px}
  .person h4{font-size:19px;font-weight:700;color:var(--negro)}
  .person .role{font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--azul);margin-top:3px}
  .story{max-width:720px;margin:14px auto 0;text-align:center;color:var(--gris);font-size:16.5px}

  .ctaband{background:var(--grad);border-radius:26px;padding:54px 40px;text-align:center;color:#fff;position:relative;overflow:hidden}
  .ctaband h2{font-size:32px;font-weight:800;letter-spacing:-.5px;color:#fff}
  .ctaband p{font-size:17px;color:#eafaff;margin:10px auto 26px;max-width:560px}
  .ctaband .btn-primary{background:#fff;color:var(--azul);box-shadow:0 12px 30px rgba(0,0,0,.18)}

  footer{background:var(--negro);color:#c4ccd8;padding:60px 0 30px}
  .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:40px}
  @media(max-width:760px){.foot-grid{grid-template-columns:1fr}}
  footer img.logo{height:42px;width:auto;margin-bottom:16px}
  .foot-about{font-size:14.5px;max-width:300px}
  footer h5{color:#fff;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:14px}
  footer ul{list-style:none;font-size:14.5px;line-height:2}
  footer a:hover{color:var(--celeste)}
  footer .muted{color:#7c8694}
  .foot-bot{border-top:1px solid rgba(255,255,255,.1);margin-top:40px;padding-top:20px;font-size:12.5px;color:#7c8694;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
  .wa-pill{display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;padding:10px 16px;border-radius:10px;font-weight:700;font-size:14px}
</style>
