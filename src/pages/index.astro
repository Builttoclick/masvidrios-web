---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
import { servicios } from '../data/servicios';
import { zonas } from '../data/zonas';

const proyectos = [
  { img: 'puerta-vidrio-corrediza-aluminio-negro-living-piscina-02.jpg', cap: 'Cerramiento corredizo · aluminio negro', cls: 'tall wide',
    alt: 'Cerramiento de vidrio corredizo con marco de aluminio negro hacia el jardín · MÁS VIDRIOS' },
  { img: 'mesa-vidrio-templado-curvado-mobiliario-01.jpg', cap: 'Mobiliario en vidrio templado', cls: '',
    alt: 'Mesa de vidrio templado curvado de dos niveles hecha a medida · MÁS VIDRIOS' },
  { img: 'cerramiento-galeria-vidrio-marco-madera-exterior.jpg', cap: 'Galería cerrada · símil madera', cls: '',
    alt: 'Cerramiento de galería con vidrio y carpintería color madera · MÁS VIDRIOS' },
  { img: 'muro-cortina-vidrio-fachada-edificio-ladrillo.jpg', cap: 'Muro cortina · fachada comercial', cls: '',
    alt: 'Muro cortina de vidrio en fachada de edificio con ladrillo visto · MÁS VIDRIOS' },
  { img: 'divisiones-vidrio-aluminio-negro-oficina-corporativa.jpg', cap: 'Divisiones de oficina · aluminio negro', cls: 'wide',
    alt: 'Divisiones de vidrio con aluminio negro en oficina corporativa · MÁS VIDRIOS' },
  { img: 'puerta-corrediza-vidrio-aluminio-negro-estilo-industrial-cuadricula.jpg', cap: 'Corrediza estilo industrial', cls: '',
    alt: 'Puerta corrediza de vidrio estilo industrial con cuadrícula · MÁS VIDRIOS' },
];

// Tira de materiales (motion + keywords SEO)
const tira = ['Vidrio templado', 'DBH · doble vidriado hermético', 'Cerramientos', 'Mamparas de baño', 'Carpintería de aluminio', 'Divisiones de oficina', 'Barandas vidriadas', 'Policarbonato', 'Cielo raso Durlock', 'Muro cortina'];

// H1 visible: institucional + keyword (vidrio templado + San Lorenzo). "Gran Asunción" queda en el title/meta/cuerpo para SEO, no en el H1 (a pedido de la familia).
const h1 = 'Vidrio templado, cerramientos y aberturas de aluminio en San Lorenzo';
const desc = 'MÁS VIDRIOS: vidrio templado, cerramientos, mamparas, divisorias de oficina y aberturas de aluminio en San Lorenzo y la Gran Asunción. Empresa familiar con más de 17 años y +1.800 trabajos realizados. Presupuesto sin compromiso, vamos a tu obra.';
---
<Base description={desc}>
  <div class="scrollbar" id="sbar" aria-hidden="true"></div>

  <!-- HERO -->
  <section class="hero">
    <div class="aurora" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow reveal" style="--d:.05s">Vidrio templado · Aluminio · {site.city}</span>
          <h1 class="reveal" style="--d:.12s">{h1}</h1>
          <p class="lead reveal" style="--d:.2s">Empresa familiar de San Lorenzo con más de 17 años y +1.800 trabajos en la Gran Asunción. Te asesoramos sobre la solución que mejor funciona para tu obra, no solo sobre el precio, y cuidamos cada terminación.</p>
          <div class="hero-actions reveal" style="--d:.28s">
            <a class="btn btn-primary" href={site.whatsapp} target="_blank" rel="noopener">Contactanos</a>
            <a class="btn btn-ghost" href="/proyectos/">Ver proyectos</a>
          </div>
          <p class="hero-trust reveal" style="--d:.36s">El dueño atiende y va a tu obra · Presupuesto sin compromiso</p>
        </div>
        <div class="hero-media reveal" style="--d:.22s">
          <div class="hero-frame" data-parallax data-tilt>
            <img src="/fotos/proyectos/cerramiento-galeria-vidrio-marco-madera-exterior.jpg" alt="Galería cerrada con vidrio y carpintería color madera · MÁS VIDRIOS" width="900" height="600" fetchpriority="high" />
            <span class="sheen" aria-hidden="true"></span>
            <div class="hero-badge"><span class="pulse" aria-hidden="true"></span>Trabajando en San Lorenzo y la Gran Asunción</div>
          </div>
        </div>
      </div>
    </div>
    <!-- Stats flotantes en vidrio esmerilado, solapados sobre el hero -->
    <div class="wrap">
      <div class="hero-stats">
        <div class="gstat glass reveal" style="--d:.08s"><b data-count-to="1800" data-pre="+">0</b><span>trabajos realizados</span></div>
        <div class="gstat glass reveal" style="--d:.16s"><b data-count-to={site.yearsExp} data-post="+">0</b><span>años de experiencia</span></div>
        <div class="gstat glass reveal" style="--d:.24s"><b><span class="g">Olimpia</span></b><span>Palcos VIP · M. Ferreira</span></div>
        <div class="gstat glass reveal" style="--d:.32s"><b><span class="g">ANDE</span></b><span>Fachada SITRANDE</span></div>
      </div>
    </div>
  </section>

  <!-- TIRA DE MATERIALES (marquee) -->
  <div class="marquee" aria-hidden="true">
    <div class="mq-track">
      {[...tira, ...tira].map((m) => (<Fragment><span>{m}</span><span class="dot">✦</span></Fragment>))}
    </div>
  </div>

  <!-- SERVICIOS (H2 = servicios prominentes) -->
  <section id="servicios">
    <div class="wrap center">
      <span class="eyebrow reveal">Lo que hacemos</span>
      <h2 class="sec reveal" style="--d:.06s">Soluciones en vidrio &amp; mucho más</h2>
      <p class="sec-sub reveal" style="--d:.12s">Del vidrio templado a la carpintería de aluminio: proveemos e instalamos, a medida y a tu presupuesto.</p>
    </div>
    <div class="wrap">
      <div class="cards">
        {servicios.map((s, i) => (
          <a class="card tilt reveal" style={`--d:${0.05 * (i % 3)}s`} href={`/servicios/${s.slug}/`} data-tilt>
            <span class="card-sheen" aria-hidden="true"></span>
            <div class="ic"><svg viewBox="0 0 24 24" set:html={s.icon}></svg></div>
            <h3>{s.nombre}</h3>
            <p>{s.hero}</p>
            <span class="more">Ver servicio</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- GALERIA -->
  <section id="proyectos" class="gal" style="background:var(--bg2)">
    <div class="wrap center">
      <span class="eyebrow reveal">Portfolio</span>
      <h2 class="sec reveal" style="--d:.06s">Proyectos que hablan por nosotros</h2>
      <p class="sec-sub reveal" style="--d:.12s">Residencias, oficinas y locales en San Lorenzo y la Gran Asunción. Una muestra de trabajos terminados.</p>
    </div>
    <div class="wrap">
      <div class="grid-gal">
        {proyectos.map((p, i) => (
          <figure class={`${p.cls} reveal`} style={`--d:${0.05 * i}s`} data-tilt>
            <img src={`/fotos/proyectos/${p.img}`} alt={p.alt} loading="lazy" />
            <span class="sheen" aria-hidden="true"></span>
            <figcaption>{p.cap}</figcaption>
          </figure>
        ))}
      </div>
      <div class="center" style="margin-top:36px"><a class="btn btn-ghost" href="/proyectos/">Ver todos los proyectos</a></div>
    </div>
  </section>

  <!-- DESTACADOS -->
  <section id="destacados">
    <div class="wrap">
      <div class="feat reveal">
        <div class="feat-aurora" aria-hidden="true"></div>
        <div class="feat-in">
        <span class="eyebrow">Obras destacadas</span>
        <h2>Cuando el trabajo tiene que estar impecable, nos llaman a nosotros.</h2>
        <div class="feat-list">
          <div class="feat-item"><div class="dot">★</div><div><h4>Palcos VIP, Club Olimpia</h4><p>Vidriado de los palcos VIP del Estadio Manuel Ferreira.</p></div></div>
          <div class="feat-item"><div class="dot">★</div><div><h4>Fachada SITRANDE / ANDE</h4><p>Fachada del sindicato de la ANDE sobre Tte. Fariña, Asunción.</p></div></div>
          <div class="feat-item"><div class="dot">✦</div><div><h4>Residencias &amp; oficinas</h4><p>Cerramientos, divisorios y aberturas en obra pública y privada.</p></div></div>
          <div class="feat-item"><div class="dot">✦</div><div><h4>Locales comerciales</h4><p>Vidrieras, muros cortina y fachadas de gran formato.</p></div></div>
        </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ZONAS -->
  <section style="padding-top:0">
    <div class="wrap center">
      <span class="eyebrow reveal">Dónde trabajamos</span>
      <h2 class="sec reveal" style="--d:.06s">Zonas que cubrimos</h2>
      <p class="sec-sub reveal" style="--d:.12s">Con base en San Lorenzo, llegamos a toda la Gran Asunción. La visita para presupuestar es sin cargo.</p>
      <div class="chips" style="justify-content:center;margin-top:26px">
        {zonas.map((z) => <a class="chip" href={`/areas/${z.slug}/`}>{z.nombre}</a>)}
      </div>
    </div>
  </section>

  <!-- NOSOTROS / EQUIPO -->
  <section id="nosotros" style="background:var(--bg2)">
    <div class="wrap center">
      <span class="eyebrow reveal">Quiénes somos</span>
      <h2 class="sec reveal" style="--d:.06s">Una empresa familiar</h2>
      <p class="story reveal" style="--d:.12s">Nacimos de la experiencia que nuestra familia acumuló en el rubro del vidrio. José, el dueño, va personalmente a cada obra: te asesora sobre la solución que mejor funciona para tu espacio y se asegura de que cada terminación quede impecable. Trabajamos con honestidad, responsabilidad y seriedad, para proteger la inversión de cada cliente.</p>
      <div class="team">
        <div class="person reveal">
          <div class="ph"><img src="/fotos/equipo/jose.jpg" alt="José, fundador y director de MÁS VIDRIOS" loading="lazy" /></div>
          <div class="body"><h4>José</h4><div class="role">Fundador &amp; Director</div></div>
        </div>
        <div class="person reveal" style="--d:.1s">
          <div class="ph"><img src="/fotos/equipo/erika.jpg" alt="Erika, administración de MÁS VIDRIOS" loading="lazy" /></div>
          <div class="body"><h4>Erika</h4><div class="role">Administración &amp; Atención al Cliente</div></div>
        </div>
      </div>
      <div style="margin-top:34px"><a class="btn btn-ghost" href="/sobre-nosotros/">Conocé nuestra historia</a></div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="wrap">
      <div class="ctaband reveal">
        <h2>Contanos tu proyecto</h2>
        <p>Te asesoramos y vamos a tu obra o domicilio. Presupuesto sin compromiso.</p>
        <a class="btn btn-white" href={site.whatsapp} target="_blank" rel="noopener">Contactanos ahora</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO con aurora + reflejo de luz ===== */
  .hero{position:relative;overflow:hidden;background:radial-gradient(120% 90% at 80% -10%,#eaf3ff 0%,var(--bg2) 55%)}
  .hero .wrap{position:relative;z-index:2}
  .hero-grid{display:grid;grid-template-columns:1.05fr 1fr;align-items:center;gap:50px;min-height:560px;padding-top:24px}
  .hero-copy{padding:64px 0}
  .hero h1{font-size:50px;line-height:1.07;letter-spacing:-1.6px;font-weight:800;margin:16px 0 18px;background:linear-gradient(135deg,#11203a 40%,#2478FC 120%);-webkit-background-clip:text;background-clip:text;color:transparent}
  .hero p.lead{font-size:18px;color:var(--gris);max-width:500px;margin-bottom:28px}
  .hero-actions{display:flex;gap:14px;flex-wrap:wrap}
  .hero-trust{margin-top:18px;font-size:13px;color:var(--gris);font-weight:600}

  /* aurora de luz azul flotante */
  .aurora{position:absolute;inset:0;z-index:1;overflow:hidden;pointer-events:none}
  .aurora span{position:absolute;border-radius:50%;filter:blur(64px);opacity:.55}
  .aurora span:nth-child(1){width:440px;height:440px;background:rgba(36,120,252,.40);top:-140px;left:-90px;animation:floatA 15s ease-in-out infinite}
  .aurora span:nth-child(2){width:380px;height:380px;background:rgba(72,216,252,.34);top:20px;right:-120px;animation:floatB 19s ease-in-out infinite}
  .aurora span:nth-child(3){width:320px;height:320px;background:rgba(84,228,228,.28);bottom:-160px;left:38%;animation:floatA 17s ease-in-out infinite reverse}
  @keyframes floatA{0%,100%{transform:translate(0,0)}50%{transform:translate(46px,34px)}}
  @keyframes floatB{0%,100%{transform:translate(0,0)}50%{transform:translate(-44px,22px)}}

  /* marco de la foto = panel de vidrio con reflejo */
  .hero-media{position:relative;min-height:520px;display:flex;align-items:center}
  .hero-frame{position:relative;width:100%;height:100%;min-height:480px;border-radius:22px;overflow:hidden;box-shadow:0 30px 70px rgba(20,40,90,.22);will-change:transform;transform:perspective(1100px) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg)) translateY(var(--py,0px));transition:transform .3s ease}
  .hero-frame img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .hero-frame::after{content:"";position:absolute;inset:0;border-radius:22px;box-shadow:inset 0 1px 0 rgba(255,255,255,.5),inset 0 0 0 1px rgba(255,255,255,.18)}
  .sheen{position:absolute;inset:0;pointer-events:none;background:linear-gradient(115deg,transparent 32%,rgba(255,255,255,.55) 48%,transparent 62%);transform:translateX(-130%);animation:sheen 6s ease-in-out 1.4s infinite}
  @keyframes sheen{0%{transform:translateX(-130%)}24%,100%{transform:translateX(130%)}}
  .hero-badge{position:absolute;left:16px;bottom:16px;display:flex;align-items:center;gap:9px;padding:10px 15px;border-radius:13px;font-size:12.5px;font-weight:700;color:#11203a;background:rgba(255,255,255,.62);backdrop-filter:blur(14px) saturate(1.4);-webkit-backdrop-filter:blur(14px) saturate(1.4);border:1px solid rgba(255,255,255,.7);box-shadow:0 10px 30px rgba(20,40,90,.18);max-width:78%}
  .pulse{width:9px;height:9px;border-radius:50%;background:#27c06a;box-shadow:0 0 0 0 rgba(39,192,106,.6);animation:pulse 2s infinite;flex:0 0 auto}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(39,192,106,.55)}70%{box-shadow:0 0 0 9px rgba(39,192,106,0)}100%{box-shadow:0 0 0 0 rgba(39,192,106,0)}}

  /* stats en vidrio esmerilado, solapando el hero */
  .glass{background:rgba(255,255,255,.55);backdrop-filter:blur(16px) saturate(1.4);-webkit-backdrop-filter:blur(16px) saturate(1.4);border:1px solid rgba(255,255,255,.75)}
  .hero-stats{position:relative;z-index:3;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:-46px 0 64px}
  .gstat{border-radius:16px;padding:20px 16px;text-align:center;box-shadow:0 16px 44px rgba(20,40,90,.13);transition:transform .25s ease,box-shadow .25s ease}
  .gstat:hover{transform:translateY(-5px);box-shadow:0 22px 54px rgba(20,40,90,.18)}
  .gstat b{display:block;font-size:32px;font-weight:800;letter-spacing:-1.2px;color:var(--negro);line-height:1}
  .gstat b .g{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
  .gstat span{font-size:12.5px;color:var(--gris);margin-top:7px;display:block}

  @media(max-width:860px){
    .hero-grid{grid-template-columns:1fr;min-height:auto;gap:30px}
    .hero-media{min-height:300px}.hero-frame{min-height:300px}.hero-copy{padding:46px 0 8px}.hero h1{font-size:34px}
    .hero-stats{grid-template-columns:1fr 1fr;margin:18px 0 0}
  }

  /* ===== Tira de materiales ===== */
  .marquee{overflow:hidden;border-top:1px solid var(--linea);border-bottom:1px solid var(--linea);background:#fff;padding:16px 0;-webkit-mask:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);mask:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent)}
  .mq-track{display:flex;align-items:center;gap:30px;width:max-content;white-space:nowrap;animation:mq 34s linear infinite}
  .marquee:hover .mq-track{animation-play-state:paused}
  .mq-track span{font-size:19px;font-weight:800;letter-spacing:-.4px;color:#11203a}
  .mq-track span.dot{color:var(--azul);font-size:13px}
  @keyframes mq{to{transform:translateX(-50%)}}

  /* ===== Service cards: tilt + reflejo ===== */
  .card.tilt{position:relative;overflow:hidden;transform-style:preserve-3d;transform:perspective(900px) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg)) translateY(var(--ty,0px));transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
  .card.tilt:hover{--ty:-6px;box-shadow:var(--shadow);border-color:transparent}
  .card .card-sheen{position:absolute;inset:0;pointer-events:none;opacity:0;transition:opacity .3s ease;background:radial-gradient(240px circle at var(--mx,50%) var(--my,50%),rgba(72,216,252,.20),transparent 60%)}
  .card.tilt:hover .card-sheen{opacity:1}
  .card.tilt>*:not(.card-sheen){position:relative;transform:translateZ(22px)}

  /* ===== Galería: reflejo al pasar ===== */
  .gal{}
  .grid-gal figure .sheen{border-radius:16px;animation:none;opacity:0;background:linear-gradient(115deg,transparent 35%,rgba(255,255,255,.45) 50%,transparent 65%);transform:translateX(-130%);transition:opacity .2s}
  .grid-gal figure:hover .sheen{opacity:1;animation:sheen 1.1s ease}

  /* ===== Sección oscura con aurora animada ===== */
  .feat{background:var(--negro);color:#fff;border-radius:26px;overflow:hidden;position:relative;isolation:isolate}
  .feat-aurora{position:absolute;inset:-20%;z-index:0;background:radial-gradient(600px circle at 18% 12%,rgba(36,120,252,.55),transparent 46%),radial-gradient(520px circle at 86% 88%,rgba(84,228,228,.38),transparent 46%);opacity:.7;animation:auroraShift 16s ease-in-out infinite}
  @keyframes auroraShift{0%,100%{transform:scale(1) translate(0,0)}50%{transform:scale(1.18) translate(24px,-14px)}}
  .feat-in{position:relative;z-index:1;padding:60px 54px}
  .feat .eyebrow{color:var(--celeste)}
  .feat h2{font-size:30px;font-weight:800;letter-spacing:-.5px;margin:8px 0 26px;max-width:680px;line-height:1.2;color:#fff}
  .feat-list{display:grid;grid-template-columns:1fr 1fr;gap:22px}
  @media(max-width:680px){.feat-list{grid-template-columns:1fr}.feat-in{padding:40px 26px}}
  .feat-item{display:flex;gap:14px;align-items:flex-start}
  .feat-item .dot{flex:0 0 auto;width:42px;height:42px;border-radius:11px;background:rgba(255,255,255,.10);display:flex;align-items:center;justify-content:center;font-weight:800;color:var(--celeste)}
  .feat-item h4{font-size:17px;font-weight:700;color:#fff}
  .feat-item p{font-size:14px;color:#aab2c0}

  .team{display:grid;grid-template-columns:repeat(2,1fr);gap:26px;margin-top:40px;max-width:720px;margin-left:auto;margin-right:auto}
  .person{background:#fff;border:1px solid var(--linea);border-radius:20px;overflow:hidden;text-align:center;transition:.2s}
  .person:hover{box-shadow:var(--shadow);transform:translateY(-4px)}
  .person .ph{overflow:hidden;background:#222}
  .person .ph img{width:100%;height:auto;display:block;transition:transform .4s ease}
  .person:hover .ph img{transform:scale(1.05)}
  .person .body{padding:20px}
  .person h4{font-size:19px;font-weight:700}
  .person .role{font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--azul);margin-top:3px}
  .story{max-width:720px;margin:14px auto 0;color:var(--gris);font-size:16.5px}

  /* barra de progreso de scroll */
  .scrollbar{position:fixed;top:0;left:0;height:3px;width:100%;transform:scaleX(0);transform-origin:0 50%;background:var(--grad);z-index:100;will-change:transform}

  @media(prefers-reduced-motion:reduce){
    .aurora span,.sheen,.feat-aurora,.mq-track,.pulse{animation:none!important}
    .hero-frame,.card.tilt{transform:none!important}
  }
</style>

<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var sb = document.getElementById('sbar');
    var parallax = document.querySelectorAll('[data-parallax]');

    function onScroll() {
      if (sb) {
        var de = document.documentElement;
        var max = (de.scrollHeight - de.clientHeight) || 1;
        sb.style.transform = 'scaleX(' + Math.min(de.scrollTop / max, 1) + ')';
      }
      if (!reduce) {
        parallax.forEach(function (el) {
          var t = el.getBoundingClientRect().top;
          el.style.setProperty('--py', (t * -0.035) + 'px');
        });
      }
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    if (!reduce && window.matchMedia('(hover:hover)').matches) {
      document.querySelectorAll('[data-tilt]').forEach(function (el) {
        var max = el.classList.contains('hero-frame') ? 5 : 7;
        el.addEventListener('pointermove', function (e) {
          var r = el.getBoundingClientRect();
          var px = (e.clientX - r.left) / r.width, py = (e.clientY - r.top) / r.height;
          el.style.setProperty('--ry', ((px - 0.5) * max * 2) + 'deg');
          el.style.setProperty('--rx', ((0.5 - py) * max * 2) + 'deg');
          el.style.setProperty('--mx', (e.clientX - r.left) + 'px');
          el.style.setProperty('--my', (e.clientY - r.top) + 'px');
        });
        el.addEventListener('pointerleave', function () {
          el.style.setProperty('--rx', '0deg');
          el.style.setProperty('--ry', '0deg');
        });
      });
    }
  })();
</script>
