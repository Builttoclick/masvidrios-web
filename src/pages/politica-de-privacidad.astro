</style>

<script is:inline>
  (function () {
    var buttons = document.querySelectorAll('[data-set-lang]');
    var blocks = document.querySelectorAll('[data-lang]');
    function apply(lang) {
      blocks.forEach(function (el) { el.hidden = el.getAttribute('data-lang') !== lang; });
      buttons.forEach(function (b) { b.classList.toggle('is-active', b.getAttribute('data-set-lang') === lang); });
      document.documentElement.lang = lang;
      try { localStorage.setItem('pp-lang', lang); } catch (e) {}
    }
    var stored = null;
    try { stored = localStorage.getItem('pp-lang'); } catch (e) {}
    var initial = stored || ((navigator.language || 'es').toLowerCase().indexOf('en') === 0 ? 'en' : 'es');
    apply(initial);
    buttons.forEach(function (b) {
      b.addEventListener('click', function () { apply(b.getAttribute('data-set-lang')); });
    });
  })();
</script>
