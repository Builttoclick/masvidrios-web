  .lang-toggle button:hover{color:var(--azul)}
  .lang-toggle button.is-active{background:var(--azul);color:#fff}

  .legal .toc{background:var(--bg2);border:1px solid var(--linea);border-radius:14px;padding:22px 26px;margin:0 0 34px}
  .legal .toc b{display:block;font-size:13px;letter-spacing:1.5px;text-transform:uppercase;color:var(--negro);margin-bottom:12px}
  .legal .toc ol{margin:0;padding-left:20px;list-style:decimal;columns:2;column-gap:32px}
  .legal .toc li{padding:4px 0;font-size:14.5px;break-inside:avoid}
  .legal .toc a{color:var(--tinta);border:none;font-weight:600}
  .legal .toc a:hover{color:var(--azul)}
  @media(max-width:600px){.legal .toc ol{columns:1}}

  .legal h2{scroll-margin-top:90px}
  .legal .table-scroll{overflow-x:auto;margin:0 0 22px}
  .legal table{width:100%;border-collapse:collapse;font-size:14.5px;min-width:520px}
