---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
import { getCollection } from 'astro:content';

const proyectos = (await getCollection('proyectos')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const title = 'Proyectos de vidrio y aluminio';
const titleTail = 'cerramientos, divisiones, fachadas y mamparas que hicimos en San Lorenzo y Gran Asunción';
const desc = 'Galería de proyectos de MÁS VIDRIOS: cerramientos, divisiones de oficina, fachadas, mamparas y mobiliario en vidrio templado y aluminio en San Lorenzo y Gran Asunción.';
---
<Base title={title} titleTail={titleTail} description={desc}>
  <section class="phero">
    <div class="wrap">
      <div class="crumbs"><a href="/">Inicio</a> › Proyectos</div>
      <h1>Proyectos que <span class="hl">hablan por nosotros</span></h1>
      <p>Residencias, oficinas y locales en San Lorenzo y toda Gran Asunción. Mirá algunos de nuestros trabajos terminados.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="proj-grid">
        {proyectos.map((p) => (
          <a class="proj-card reveal" href={`/proyectos/${p.id}/`}>
            <div class="proj-img">
              {p.data.portada && <img src={p.data.portada} alt={p.data.portada_alt ?? p.data.titulo} loading="lazy" />}
              <span class="proj-tag">{p.data.tipo}</span>
            </div>
            <div class="proj-body">
              <h3>{p.data.titulo}</h3>
              <p>{p.data.resumen}</p>
              <span class="proj-zona">{p.data.zona}{p.data.anio ? ` · ${p.data.anio}` : ''}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap">
      <div class="ctaband">
        <h2>¿Querés un trabajo así?</h2>
        <p>Contanos tu proyecto y te asesoramos sin compromiso. Vamos a tu obra o domicilio.</p>
        <a class="btn btn-white" href={site.whatsapp} target="_blank" rel="noopener">Contactanos</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  @media(max-width:860px){.proj-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:560px){.proj-grid{grid-template-columns:1fr}}
  .proj-card{background:#fff;border:1px solid var(--linea);border-radius:18px;overflow:hidden;transition:.2s}
  .proj-card:hover{transform:translateY(-5px);box-shadow:var(--shadow);border-color:transparent}
  .proj-img{position:relative;aspect-ratio:4/3;overflow:hidden;background:#eef}
  .proj-img img{width:100%;height:100%;object-fit:cover;transition:.4s}
  .proj-card:hover .proj-img img{transform:scale(1.06)}
  .proj-tag{position:absolute;top:12px;left:12px;background:rgba(26,26,26,.78);color:#fff;font-size:12px;font-weight:700;padding:5px 12px;border-radius:999px;backdrop-filter:blur(4px)}
  .proj-body{padding:20px 22px}
  .proj-body h3{font-size:17.5px;font-weight:700;margin-bottom:6px}
  .proj-body p{font-size:14px;color:var(--gris);margin-bottom:12px}
  .proj-zona{font-size:12.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--azul)}
</style>
