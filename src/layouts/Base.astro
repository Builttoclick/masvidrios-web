---
export interface Props {
  title?: string;
  description?: string;
  schema?: object | object[];
}

const {
  title = 'MÁS VIDRIOS — Vidrio templado, aluminio y cerramientos en San Lorenzo',
  description = 'Empresa familiar desde 2009. Colocación de vidrios, cerramientos, mamparas, divisorias de oficina y aberturas de aluminio en San Lorenzo, Paraguay. Presupuesto sin compromiso.',
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'GlassMerchant',
  name: 'MÁS VIDRIOS',
  description,
  image: new URL('/brand/logo.png', Astro.site).toString(),
  url: Astro.site?.toString(),
  telephone: '+595984452749',
  email: 'jose@masvidrios.com.py',
  foundingDate: '2009',
  areaServed: { '@type': 'Country', name: 'Paraguay' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'San Lorenzo',
    addressCountry: 'PY',
  },
  sameAs: ['https://www.facebook.com/MASVidrios-461790940665213/'],
};

const schemas = schema
  ? (Array.isArray(schema) ? [localBusiness, ...schema] : [localBusiness, schema])
  : [localBusiness];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#2478FC" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL('/brand/logo.png', Astro.site).toString()} />
  <meta property="og:locale" content="es_PY" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  :root{
    --azul:#2478FC; --celeste:#48D8FC; --turquesa:#54E4E4;
    --negro:#1A1A1A; --tinta:#2b3340; --gris:#69727f; --linea:#e8edf3;
    --bg:#ffffff; --bg2:#f6f9fd;
    --grad:linear-gradient(135deg,#2478FC 0%,#48D8FC 60%,#54E4E4 100%);
    --shadow:0 18px 50px rgba(20,40,90,.10);
    --radius:18px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:'Manrope',system-ui,'Segoe UI',Arial,sans-serif;color:var(--tinta);background:var(--bg);line-height:1.6;-webkit-font-smoothing:antialiased}
  img{display:block;max-width:100%}
  a{text-decoration:none;color:inherit}
</style>
